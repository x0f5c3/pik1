     handlers: Handlers,
     good_types: Mutex<BTreeSet<TypeId>>,
 }
@@ -256,6 +257,7 @@ impl McuConnection {
         let inner = Arc::new(McuConnectionInner {
             dictionary: OnceCell::new(),
+            raw_dictionary_bytes: OnceCell::new(),
             handlers: Handlers::default(),
             good_types: Mutex::default(),
         });
@@ -295,6 +297,10 @@ impl McuConnection {
                 identify_data.append(&mut data.data);
             }
         }
+        conn.inner
+            .raw_dictionary_bytes
+            .set(identify_data.clone())
+            .expect("raw dictionary bytes already set");
         let mut decoder = flate2::read::ZlibDecoder::new(identify_data.as_slice());
         let mut buf = Vec::new();
         decoder
@@ -313,6 +319,14 @@ impl McuConnection {
 
         Ok(conn)
     }
+
+    /// Return the raw compressed dictionary bytes fetched during [`Self::connect`].
+    ///
+    /// These are the concatenated `identify_response.data` chunks before zlib
