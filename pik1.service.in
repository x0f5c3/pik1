[Unit]
Description=PiK1 gadget setup and serialmux bridge
DefaultDependencies=no
After=sysinit.target local-fs.target systemd-udevd.service
Before=klipper.service mediamtx.service

[Service]
Type=simple

# Gadget setup must run as root (writes to /sys/kernel/config)
ExecStartPre=+@INSTALL_DIR@/setup_pik1.sh

# Daemon runs as the klipper user so PTY devices are accessible to klipper
User=1000
Group=1000

ExecStart=@INSTALL_DIR@/serialmux host /dev/ttyGS0 \
    mcu:0:/tmp/klipper_mcu \
    mcu:1:/tmp/klipper_toolhead

# windlass-bridge alternative (NOT compatible with serialmux):
# Both ends (K1 exporter + Pi host) must run windlass-bridge together.
# Build: cd serialmux-rs && cargo build --release --features windlass
# Install binary to /opt/pik1/windlass-bridge, then comment out ExecStart
# above and uncomment the block below.  Update printer.cfg to use socket
# paths (/tmp/klipper_mcu0, /tmp/klipper_mcu1) instead of PTY paths.
#ExecStart=/opt/pik1/windlass-bridge host /dev/ttyGS0 \
#    mcu:0:/tmp/klipper_mcu0 \
#    mcu:1:/tmp/klipper_mcu1

Restart=always
RestartSec=2

StandardOutput=journal
StandardError=journal
SyslogIdentifier=pik1

[Install]
WantedBy=multi-user.target
