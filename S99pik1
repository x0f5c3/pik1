#!/bin/sh
# /etc/init.d/S99serialmux-exporter
# serialmux exporter -- bridges MCU UARTs to the Pi over USB CDC ACM.

PYTHON="/usr/share/klippy-env/bin/python"
SCRIPT="/usr/data/pik1/serialmux.py"
PIDFILE="/var/run/serialmux-exporter.pid"
LOGFILE="/tmp/serialmux-exporter.log"

USB_ID="1d6b:0104"
MCU_DEV="/dev/ttyS7"
MCU_BAUD="230400"
NOZZLE_DEV="/dev/ttyS1"
NOZZLE_BAUD="230400"

DAEMON_ARGS="exporter --usb $USB_ID mcu:0:$MCU_DEV:$MCU_BAUD mcu:1:$NOZZLE_DEV:$NOZZLE_BAUD"

# --- windlass-bridge alternative (NOT compatible with serialmux) ---
# Both ends (K1 exporter + Pi host) must run windlass-bridge together.
# Build with: cd serialmux-rs && cargo build --release --features windlass
# Install binary to /usr/data/pik1/windlass-bridge, then:
#   1. Uncomment WINDLASS_ARGS below.
#   2. Replace the "SCRIPT / PYTHON" ExecStart block with the windlass one.
#   3. Also update pik1.service on the Pi to use windlass-bridge host mode.
#WINDLASS_ARGS="exporter --usb $USB_ID mcu:0:$MCU_DEV:$MCU_BAUD mcu:1:$NOZZLE_DEV:$NOZZLE_BAUD"

case "$1" in
    start)
        if [ ! -x "$PYTHON" ]; then
            echo "Error: python not found at $PYTHON" >&2
            exit 1
        fi
        if [ ! -f "$SCRIPT" ]; then
            echo "Error: serialmux.py not found at $SCRIPT" >&2
            exit 1
        fi
        echo "Starting serialmux exporter..."
        # The redirect must be inside the child process, not on start-stop-daemon
        # itself, otherwise the daemonized child inherits /dev/null for stdio.
        # We pass a shell wrapper so the redirect is applied before exec.
        start-stop-daemon -S -b -m -p "$PIDFILE" \
            -x /bin/sh -- -c \
            "exec $PYTHON $SCRIPT $DAEMON_ARGS >> $LOGFILE 2>&1"
        # windlass-bridge alternative (uncomment and comment out block above):
        #WINDLASS="/usr/data/pik1/windlass-bridge"
        #start-stop-daemon -S -b -m -p "$PIDFILE" \
        #    -x /bin/sh -- -c \
        #    "exec $WINDLASS $WINDLASS_ARGS >> $LOGFILE 2>&1"
        ;;
    stop)
        echo "Stopping serialmux exporter..."
        start-stop-daemon -K -p "$PIDFILE" 2>/dev/null
        rm -f "$PIDFILE"
        ;;
    restart|reload)
        "$0" stop
        sleep 1
        "$0" start
        ;;
    status)
        if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
            echo "serialmux exporter is running (pid $(cat "$PIDFILE"))"
        else
            echo "serialmux exporter is not running"
            exit 1
        fi
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|reload|status}" >&2
        exit 1
        ;;
esac
